{
  "name": "cost-aware-llm-router",
  "version": "1.0.0",
  "description": "Cost-Aware LLM Model Router with Budget-Constrained Intelligent Routing",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "test": "jest --coverage",
    "type-check": "tsc --noEmit",
    "docker:build": "docker build -t cost-aware-llm-router:latest .",
    "docker:run": "docker run -p 3000:3000 --env-file .env.local cost-aware-llm-router:latest",
    "docker:up": "docker-compose up",
    "docker:down": "docker-compose down"
  },
  "dependencies": {
    "axios": "^1.6.0",
    "cohere-ai": "^8.0.0",
    "dotenv": "^16.3.1",
    "next": "^14.0.0",
    "openai": "^6.34.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "devDependencies": {
    "@testing-library/react": "^14.0.0",
    "@types/node": "^20.0.0",
    "@types/react": "^18.2.0",
    "eslint": "^8.50.0",
    "eslint-config-next": "^14.0.0",
    "jest": "^29.0.0",
    "typescript": "^5.0.0"
  }
}
